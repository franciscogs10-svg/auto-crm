# Turso (cloud SQLite) — Required for cloud deployment
# Get these from: turso db show <name> --url / turso db tokens create <name>
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Optional — AI features in web UI
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — Voice transcription (Gemini)
# Get from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# Optional — Daily email digest (resend.com)
# RESEND_API_KEY=re_...
# DIGEST_EMAIL=you@example.com
# DIGEST_FROM=onboarding@resend.dev
